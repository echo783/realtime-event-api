<UserControl x:Class="FactoryClient.Views.RoiDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 주소창 -->
        <Border Grid.Row="0"
                Background="#F8FAFC"
                BorderBrush="#D6DCE8"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,12">
            <DockPanel LastChildFill="True">
                <TextBlock Text="주소"
                           Width="50"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="#374151"/>

                <TextBox x:Name="TxtUrl"
                         Margin="8,0,0,0"
                         Height="34"
                         VerticalContentAlignment="Center"
                         FontSize="13"
                         IsReadOnly="True"
                         Background="White"
                         BorderBrush="#CBD5E1"
                         Text="https://localhost:7125/login.html"/>
            </DockPanel>
        </Border>

        <!-- 웹 화면 -->
        <Border Grid.Row="1"
                Background="#F8FAFC"
                BorderBrush="#D6DCE8"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8">
            <wv2:WebView2 x:Name="Browser"/>
        </Border>
    </Grid>
</UserControl>