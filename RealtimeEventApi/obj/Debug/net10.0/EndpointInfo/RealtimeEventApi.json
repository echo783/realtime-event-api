          "labelRoiH": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "checkRotation": {
            "type": "boolean"
          },
          "checkLabel": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
