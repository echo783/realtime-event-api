          "lastEnded": {
            "type": "boolean"
          },
          "lastLabelEnter": {
            "type": "boolean"
          },
          "lastRotationChangeValue": {
            "type": "number",
            "format": "double"
          },
          "lastMotionRatio": {
            "type": "number",
            "format": "double"
          },
          "lastLabelChangeValue": {
            "type": "number",
            "format": "double"
          },
          "productionCount": {
            "type": "integer",
            "format": "int32"
          },
          "lastProductionAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MonitorProductionResponse": {
        "type": "object",
        "properties": {
          "cameraId": {
            "type": "integer",
            "format": "int32"
          },
          "productionCount": {
            "type": "integer",
            "format": "int32"
          },
          "lastProductionAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MonitorStatusResponse": {
        "type": "object",
